SIFT_IMAGE=sift-workstation
SIFT_TAG=latest
SIFT_CONTAINER_NAME=sift-workstation
SIFT_HOSTNAME=sift-workstation
SIFT_SSH_PORT=2222
SIFT_CASES_DIR=./cases
# SIFT_CASE_DIR=./cases/CASE_001
# SIFT_EVIDENCE_DIR=./cases/CASE_001/artifacts
TZ=UTC
TERM=xterm-256color
SIFT_NETWORK_NAME=sift_net
